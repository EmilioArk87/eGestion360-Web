@page
@model eGestion360Web.Pages.Admin.Usuarios.EditModel
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/MainMenu">Menú Principal</a></li>
            <li class="breadcrumb-item"><a asp-page="/UserManagement">Gestión de Usuarios</a></li>
            <li class="breadcrumb-item active" aria-current="page">Editar Usuario</li>
        </ol>
    </nav>

    <div class="d-flex align-items-center mb-4">
        <div class="me-3 bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center"
             style="width: 3rem; height: 3rem; min-width: 3rem;">
            <i class="fas fa-user-edit"></i>
        </div>
        <div>
            <h2 class="mb-0">Editar Usuario</h2>
            <p class="text-muted mb-0">Modifica los datos del usuario</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Username" class="form-label fw-semibold"></label>
                            <input asp-for="Username" class="form-control" autocomplete="username" />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control" autocomplete="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label">Activo</label>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input asp-for="RequirePasswordChange" class="form-check-input" />
                                <label asp-for="RequirePasswordChange" class="form-check-label">
                                    Solicitar cambio de contraseña al ingresar
                                </label>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Guardar Cambios
                            </button>
                            <a asp-page="/UserManagement" class="btn btn-outline-secondary">
                                <i class="fas fa-times me-2"></i>Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
