@page
@model eGestion360Web.Pages.EncryptPasswordsModel
@{
    ViewData["Title"] = "Encriptar Contraseñas";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>🔐 Encriptar Contraseñas de Usuario</h2>
    
    @if (!Model.HasExecuted)
    {
        <div class="alert alert-warning">
            <h5>⚠️ Importante</h5>
            <p>Esta función encriptará todas las contraseñas que estén en texto plano usando BCrypt.</p>
            <ul>
                <li>✅ Las contraseñas ya encriptadas no se modificarán</li>
                <li>🔐 Se usará BCrypt con factor de trabajo 12 (muy seguro)</li>
                <li>💾 Los cambios se guardarán automáticamente en la base de datos</li>
            </ul>
        </div>

        <div class="card">
            <div class="card-body">
                <h5 class="card-title">¿Proceder con la encriptación?</h5>
                <p class="card-text">Esto buscará todos los usuarios con contraseñas en texto plano y las convertirá a hashes seguros.</p>
                
                <form method="post">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-lock"></i> Encriptar Contraseñas Ahora
                    </button>
                    <a href="/DebugUsers" class="btn btn-info">
                        <i class="fas fa-eye"></i> Ver Usuarios Primero
                    </a>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <h5>📋 Resultado de la Encriptación</h5>
        </div>

        @foreach (var message in Model.Messages)
        {
            <div class="alert @(message.StartsWith("✅") ? "alert-success" : 
                               message.StartsWith("❌") ? "alert-danger" : 
                               message.StartsWith("⚠️") ? "alert-warning" : 
                               "alert-info")">
                @message
            </div>
        }

        <div class="mt-4">
            <a href="/Login" class="btn btn-success btn-lg">
                <i class="fas fa-sign-in-alt"></i> Probar Login Ahora
            </a>
            <a href="/DebugUsers" class="btn btn-info">
                <i class="fas fa-users"></i> Ver Estado de Usuarios
            </a>
            <a href="/EncryptPasswords" class="btn btn-secondary">
                <i class="fas fa-redo"></i> Ejecutar de Nuevo
            </a>
        </div>
    }
</div>