@page
@model eGestion360Web.Pages.Empresas.IndexModel
@{
    ViewData["Title"] = "Empresas";
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/MainMenu">Menú Principal</a></li>
            <li class="breadcrumb-item active" aria-current="page">Empresas</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="fas fa-building me-2"></i>Empresas</h2>
            <p class="text-muted mb-0">Listado de empresas registradas</p>
        </div>
        <a asp-page="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nueva Empresa
        </a>
    </div>

    @if (TempData["EmpresasMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["EmpresasMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    }

    <form method="get" class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input asp-for="Search" class="form-control" placeholder="Buscar por código, razón social, nombre comercial o identificador fiscal..." />
                <button type="submit" class="btn btn-outline-primary">Buscar</button>
                @if (!string.IsNullOrWhiteSpace(Model.Search))
                {
                    <a asp-page="Index" class="btn btn-outline-secondary">Limpiar</a>
                }
            </div>
        </div>
    </form>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Razón Social</th>
                            <th>Nombre Comercial</th>
                            <th>Identificador Fiscal</th>
                            <th>País</th>
                            <th>Moneda</th>
                            <th class="text-center">Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Empresas.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                    No hay empresas registradas.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var empresa in Model.Empresas)
                            {
                                <tr>
                                    <td><code>@empresa.Codigo</code></td>
                                    <td><strong>@empresa.RazonSocial</strong></td>
                                    <td>@(empresa.NombreComercial ?? "-")</td>
                                    <td>@(empresa.IdentificadorFiscal ?? "-")</td>
                                    <td>@empresa.PaisIso</td>
                                    <td>@empresa.MonedaIso</td>
                                    <td class="text-center">
                                        @if (empresa.Activa)
                                        {
                                            <span class="badge bg-success">Activa</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactiva</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-page="Details" asp-route-id="@empresa.IdEmpresa" class="btn btn-sm btn-outline-info" title="Detalles">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-page="Edit" asp-route-id="@empresa.IdEmpresa" class="btn btn-sm btn-outline-primary" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-page="Delete" asp-route-id="@empresa.IdEmpresa" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-page="/MainMenu" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Volver al Menú Principal
        </a>
    </div>
</div>
