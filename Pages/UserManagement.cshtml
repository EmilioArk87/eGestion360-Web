@page
@model UserManagementModel
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/MainMenu">Menú Principal</a></li>
            <li class="breadcrumb-item active" aria-current="page">Gestión de Usuarios</li>
        </ol>
    </nav>

    <div class="d-flex align-items-center mb-4">
        <div class="me-3 bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center"
             style="width: 3rem; height: 3rem; min-width: 3rem;">
            <i class="fas fa-users"></i>
        </div>
        <div>
            <h2 class="mb-0">Gestión de Usuarios</h2>
            <p class="text-muted mb-0">Administra usuarios y contraseñas del sistema</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    }

    <!-- Datos del usuario en sesión -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <h5 class="mb-3"><i class="fas fa-id-card me-2 text-primary"></i>Mi cuenta</h5>
            <div class="row align-items-center">
                <div class="col-md-4 mb-2">
                    <span class="text-muted small">Usuario</span><br>
                    <strong>@Model.Username</strong>
                </div>
                <div class="col-md-4 mb-2">
                    <span class="text-muted small">Email</span><br>
                    <strong>@Model.Email</strong>
                </div>
                <div class="col-md-4 mb-2 text-md-end">
                    <a asp-page="/ChangePassword" class="btn btn-outline-primary">
                        <i class="fas fa-key me-2"></i>Cambiar mi contraseña
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (Model.IsAdmin)
    {
        <!-- Panel de administración de usuarios -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between">
                <h5 class="mb-0 fw-semibold">
                    <i class="fas fa-users-cog me-2 text-warning"></i>Administración de Usuarios
                </h5>
                <a asp-page="/Admin/Usuarios/Create" class="btn btn-sm btn-success">
                    <i class="fas fa-user-plus me-1"></i>Nuevo Usuario
                </a>
            </div>
            <div class="card-body">
                <!-- Búsqueda -->
                <form method="get" class="row g-2 align-items-end mb-0">
                    <div class="col">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-search"></i></span>
                            <input type="text" name="search" value="@Model.Search"
                                   class="form-control" placeholder="Buscar por usuario o email..." />
                        </div>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-search me-1"></i>Buscar
                        </button>
                        @if (!string.IsNullOrEmpty(Model.Search))
                        {
                            <a asp-page="UserManagement" class="btn btn-outline-secondary ms-1">
                                <i class="fas fa-times"></i>
                            </a>
                        }
                    </div>
                </form>
            </div>

            <!-- Tabla de usuarios -->
            <div class="card-body p-0">
                @if (!Model.Users.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-user-slash fa-3x mb-3 d-block"></i>
                        No se encontraron usuarios.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Usuario</th>
                                    <th>Email</th>
                                    <th class="text-center">Estado</th>
                                    <th class="text-center">Requiere cambio</th>
                                    <th class="text-end">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model.Users)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="bg-secondary text-white rounded-circle d-inline-flex align-items-center justify-content-center me-2"
                                                     style="width: 2rem; height: 2rem; min-width: 2rem; font-size: 0.75rem;">
                                                    @user.Username.Substring(0, 1).ToUpper()
                                                </div>
                                                <strong>@user.Username</strong>
                                            </div>
                                        </td>
                                        <td class="text-muted">@user.Email</td>
                                        <td class="text-center">
                                            @if (user.IsActive)
                                            {
                                                <span class="badge bg-success">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactivo</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (user.RequirePasswordChange)
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="fas fa-exclamation-triangle me-1"></i>Sí
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">No</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <a asp-page="/Admin/Usuarios/Edit" asp-route-id="@user.Id"
                                               class="btn btn-sm btn-outline-primary me-1">
                                                <i class="fas fa-edit me-1"></i>Editar
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-warning"
                                                    data-bs-toggle="modal" data-bs-target="#modalReset"
                                                    data-userid="@user.Id"
                                                    data-username="@user.Username">
                                                <i class="fas fa-key me-1"></i>Resetear
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    <div class="mt-2">
        <a asp-page="/MainMenu" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Volver al Menú Principal
        </a>
    </div>
</div>

@if (Model.IsAdmin)
{
    <!-- Modal Reset Contraseña -->
    <div class="modal fade" id="modalReset" tabindex="-1" aria-labelledby="modalResetLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <form method="post">
                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title fw-bold" id="modalResetLabel">
                            <i class="fas fa-key me-2"></i>Resetear Contraseña
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                    </div>
                    <div class="modal-body p-4">
                        <p class="text-muted mb-3">
                            Estableciendo nueva contraseña para:
                            <strong id="modalUsername" class="text-dark"></strong>
                        </p>

                        <input type="hidden" asp-for="TargetUserId" id="inputTargetUserId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="NewPassword" class="form-control" id="inputNewPassword"
                                       placeholder="Mínimo 6 caracteres" autocomplete="new-password" />
                                <button class="btn btn-outline-secondary" type="button" id="btnTogglePassword">
                                    <i class="fas fa-eye" id="iconTogglePassword"></i>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="form-check form-switch">
                            <input asp-for="RequireChange" class="form-check-input" />
                            <label asp-for="RequireChange" class="form-check-label">
                                Solicitar cambio de contraseña al siguiente inicio de sesión
                            </label>
                        </div>

                        <div class="alert alert-warning mt-3 mb-0 small">
                            <i class="fas fa-exclamation-triangle me-1"></i>
                            Esta acción no puede deshacerse. El usuario deberá usar la nueva contraseña para acceder.
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            <i class="fas fa-times me-1"></i>Cancelar
                        </button>
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-save me-1"></i>Guardar Nueva Contraseña
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('modalReset')?.addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            document.getElementById('inputTargetUserId').value = btn.getAttribute('data-userid');
            document.getElementById('modalUsername').textContent = btn.getAttribute('data-username');
            document.getElementById('inputNewPassword').value = '';
        });

        document.getElementById('btnTogglePassword')?.addEventListener('click', function () {
            var input = document.getElementById('inputNewPassword');
            var icon = document.getElementById('iconTogglePassword');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        });
    </script>
    <style>
        .menu-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
        .menu-card:hover { transform: translateY(-5px); box-shadow: 0 0.5rem 1rem rgba(0,0,0,.15) !important; }
    </style>
}
