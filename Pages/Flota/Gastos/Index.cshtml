@page
@model eGestion360Web.Pages.Flota.Gastos.IndexModel
@{
    ViewData["Title"] = "Gastos Periódicos";
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/MainMenu">Menú Principal</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Index">Flota & KPIs</a></li>
            <li class="breadcrumb-item active">Gastos Periódicos</li>
        </ol>
    </nav>

    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-1"><i class="fas fa-file-invoice-dollar me-2 text-warning"></i>Gastos Periódicos</h2>
            <p class="text-muted mb-0">Registro de repuestos, mantenimiento y seguros</p>
        </div>
    </div>

    <div class="row g-4">

        <!-- Repuestos & Llantas -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 menu-card">
                <div class="card-body text-center p-4">
                    <div class="menu-icon bg-warning text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 4rem; height: 4rem;">
                        <i class="fas fa-cogs fa-lg"></i>
                    </div>
                    <h6 class="fw-bold mb-2">Repuestos & Llantas</h6>
                    <p class="text-muted small mb-3">Compras de repuestos y llantas</p>
                    <a asp-page="/Flota/Gastos/Repuestos/Index" class="btn btn-sm btn-warning w-100 text-white">
                        <i class="fas fa-arrow-right me-1"></i>Registrar
                    </a>
                </div>
            </div>
        </div>

        <!-- Mantenimiento -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 menu-card">
                <div class="card-body text-center p-4">
                    <div class="menu-icon bg-secondary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 4rem; height: 4rem;">
                        <i class="fas fa-wrench fa-lg"></i>
                    </div>
                    <h6 class="fw-bold mb-2">Órdenes de Mantenimiento</h6>
                    <p class="text-muted small mb-3">Servicios en talleres (preventivo / correctivo)</p>
                    <a asp-page="/Flota/Gastos/Mantenimiento/Index" class="btn btn-sm btn-secondary w-100">
                        <i class="fas fa-arrow-right me-1"></i>Registrar
                    </a>
                </div>
            </div>
        </div>

        <!-- Seguros -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 menu-card">
                <div class="card-body text-center p-4">
                    <div class="menu-icon text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 4rem; height: 4rem; background-color:#20c997;">
                        <i class="fas fa-shield-alt fa-lg"></i>
                    </div>
                    <h6 class="fw-bold mb-2">Pólizas de Seguros</h6>
                    <p class="text-muted small mb-3">Seguros por vehículo con costo diario prorateado</p>
                    <a asp-page="/Flota/Gastos/Seguros/Index" class="btn btn-sm w-100 text-white" style="background-color:#20c997;">
                        <i class="fas fa-arrow-right me-1"></i>Registrar
                    </a>
                </div>
            </div>
        </div>

    </div>

    <div class="mt-4">
        <a asp-page="/Flota/Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Volver a Flota
        </a>
    </div>
</div>

@section Scripts {
    <style>
        .menu-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
        .menu-card:hover { transform: translateY(-4px); box-shadow: 0 0.4rem 1rem rgba(0,0,0,.12) !important; }
    </style>
}
