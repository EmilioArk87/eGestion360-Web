@page
@model eGestion360Web.Pages.Flota.Gastos.Repuestos.CreateModel
@{ ViewData["Title"] = "Nuevo Gasto de Repuesto"; }
<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/MainMenu">Menú Principal</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Index">Flota & KPIs</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Gastos/Index">Gastos Periódicos</a></li>
            <li class="breadcrumb-item"><a asp-page="Index">Repuestos</a></li>
            <li class="breadcrumb-item active">Nuevo</li>
        </ol>
    </nav>
    <div class="mb-4"><h2 class="mb-1"><i class="fas fa-cogs me-2 text-warning"></i>Nuevo Gasto de Repuesto</h2></div>
    <form method="post">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-4"><label asp-for="Item.IdVehiculo" class="form-label fw-semibold"></label><select asp-for="Item.IdVehiculo" asp-items="ViewBag.Vehiculos" class="form-select"><option value="">-- Seleccione --</option></select><span asp-validation-for="Item.IdVehiculo" class="text-danger small"></span></div>
                    <div class="col-md-4"><label asp-for="Item.IdCategoriaRepuesto" class="form-label fw-semibold"></label><select asp-for="Item.IdCategoriaRepuesto" asp-items="ViewBag.Categorias" class="form-select"><option value="">-- Seleccione --</option></select><span asp-validation-for="Item.IdCategoriaRepuesto" class="text-danger small"></span></div>
                    <div class="col-md-4"><label asp-for="Item.Fecha" class="form-label fw-semibold"></label><input asp-for="Item.Fecha" type="date" class="form-control" /><span asp-validation-for="Item.Fecha" class="text-danger small"></span></div>
                    <div class="col-md-8"><label asp-for="Item.Descripcion" class="form-label fw-semibold"></label><input asp-for="Item.Descripcion" class="form-control" placeholder="Ej: Llanta trasera 275/70 R22.5" /><span asp-validation-for="Item.Descripcion" class="text-danger small"></span></div>
                    <div class="col-md-4"><label asp-for="Item.NoFactura" class="form-label fw-semibold"></label><input asp-for="Item.NoFactura" class="form-control" /></div>
                    <div class="col-md-3"><label asp-for="Item.Cantidad" class="form-label fw-semibold"></label><input asp-for="Item.Cantidad" type="number" step="0.001" min="0.001" class="form-control" id="cantidad" /><span asp-validation-for="Item.Cantidad" class="text-danger small"></span></div>
                    <div class="col-md-3"><label asp-for="Item.PrecioUnitario" class="form-label fw-semibold"></label><input asp-for="Item.PrecioUnitario" type="number" step="0.0001" min="0" class="form-control" id="precio" /><span asp-validation-for="Item.PrecioUnitario" class="text-danger small"></span></div>
                    <div class="col-md-3"><label class="form-label fw-semibold">Subtotal</label><input type="text" id="subtotal" class="form-control bg-light fw-bold text-warning" readonly /></div>
                    <div class="col-md-3"><label asp-for="Item.Moneda" class="form-label fw-semibold"></label><select asp-for="Item.Moneda" class="form-select"><option value="HNL">HNL</option><option value="USD">USD</option></select></div>
                    <div class="col-md-4"><label asp-for="Item.KmOdometro" class="form-label fw-semibold"></label><div class="input-group"><input asp-for="Item.KmOdometro" type="number" step="0.01" class="form-control" /><span class="input-group-text">km</span></div></div>
                    <div class="col-md-4"><label asp-for="Item.Proveedor" class="form-label fw-semibold"></label><input asp-for="Item.Proveedor" class="form-control" /></div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 px-4 pb-4 d-flex gap-2">
                <button type="submit" class="btn btn-warning text-white"><i class="fas fa-save me-2"></i>Guardar</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function calc() { document.getElementById('subtotal').value = ((parseFloat(document.getElementById('cantidad').value)||0)*(parseFloat(document.getElementById('precio').value)||0)).toFixed(2); }
        document.getElementById('cantidad').addEventListener('input', calc);
        document.getElementById('precio').addEventListener('input', calc);
    </script>
}
