@page
@model eGestion360Web.Pages.Flota.Gastos.Repuestos.IndexModel
@{ ViewData["Title"] = "Repuestos & Llantas"; }
<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/MainMenu">Menú Principal</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Index">Flota & KPIs</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Gastos/Index">Gastos Periódicos</a></li>
            <li class="breadcrumb-item active">Repuestos</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="fas fa-cogs me-2 text-warning"></i>Repuestos & Llantas</h2>
            <p class="text-muted mb-0">Compras de repuestos y llantas por vehículo</p>
        </div>
        <a asp-page="Create" class="btn btn-warning text-white"><i class="fas fa-plus me-2"></i>Nuevo Gasto</a>
    </div>
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show"><i class="fas fa-check-circle me-2"></i>@TempData["Mensaje"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    <form method="get" class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-4"><label class="form-label small fw-semibold">Desde</label><input type="date" name="Desde" value="@Model.Desde?.ToString("yyyy-MM-dd")" class="form-control" /></div>
                <div class="col-md-4"><label class="form-label small fw-semibold">Hasta</label><input type="date" name="Hasta" value="@Model.Hasta?.ToString("yyyy-MM-dd")" class="form-control" /></div>
                <div class="col-md-4 d-flex gap-2"><button type="submit" class="btn btn-outline-warning flex-grow-1">Filtrar</button><a asp-page="Index" class="btn btn-outline-secondary">Limpiar</a></div>
            </div>
        </div>
    </form>
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr><th>Fecha</th><th>Vehículo</th><th>Categoría</th><th>Descripción</th><th>Nº Factura</th><th class="text-end fw-bold">Subtotal</th><th>Moneda</th><th class="text-end">Acciones</th></tr>
                    </thead>
                    <tbody>
                        @if (!Model.Registros.Any())
                        {
                            <tr><td colspan="8" class="text-center text-muted py-5"><i class="fas fa-cogs fa-2x mb-2 d-block text-secondary"></i>No hay registros en el período.</td></tr>
                        }
                        else
                        {
                            foreach (var r in Model.Registros)
                            {
                                <tr>
                                    <td>@r.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td><strong>@r.Vehiculo?.Placa</strong></td>
                                    <td><span class="badge bg-warning text-dark">@r.CategoriaRepuesto?.Nombre</span></td>
                                    <td>@r.Descripcion</td>
                                    <td><code>@(r.NoFactura ?? "-")</code></td>
                                    <td class="text-end fw-bold text-warning">@r.Subtotal.ToString("N2")</td>
                                    <td>@r.Moneda</td>
                                    <td class="text-end"><a asp-page="Edit" asp-route-id="@r.IdGastoRepuesto" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit"></i></a></td>
                                </tr>
                            }
                            <tr class="table-light fw-bold"><td colspan="5" class="text-end">Total:</td><td class="text-end text-warning">@Model.Registros.Sum(r => r.Subtotal).ToString("N2")</td><td colspan="2"></td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="mt-4"><a asp-page="/Flota/Gastos/Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Volver a Gastos</a></div>
</div>
