@page
@model eGestion360Web.Pages.Flota.Gastos.Seguros.CreateModel
@{ ViewData["Title"] = "Nueva Póliza de Seguro"; }
<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/MainMenu">Menú Principal</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Index">Flota & KPIs</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Gastos/Index">Gastos Periódicos</a></li>
            <li class="breadcrumb-item"><a asp-page="Index">Seguros</a></li>
            <li class="breadcrumb-item active">Nueva</li>
        </ol>
    </nav>
    <div class="mb-4"><h2 class="mb-1"><i class="fas fa-shield-alt me-2" style="color:#20c997;"></i>Nueva Póliza de Seguro</h2></div>
    <form method="post">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-4"><label asp-for="Item.IdVehiculo" class="form-label fw-semibold"></label><select asp-for="Item.IdVehiculo" asp-items="ViewBag.Vehiculos" class="form-select"><option value="">-- Seleccione --</option></select><span asp-validation-for="Item.IdVehiculo" class="text-danger small"></span></div>
                    <div class="col-md-4"><label asp-for="Item.NoPoliza" class="form-label fw-semibold"></label><input asp-for="Item.NoPoliza" class="form-control" /><span asp-validation-for="Item.NoPoliza" class="text-danger small"></span></div>
                    <div class="col-md-4"><label asp-for="Item.Aseguradora" class="form-label fw-semibold"></label><input asp-for="Item.Aseguradora" class="form-control" /><span asp-validation-for="Item.Aseguradora" class="text-danger small"></span></div>
                    <div class="col-md-4"><label asp-for="Item.TipoCobertura" class="form-label fw-semibold"></label><select asp-for="Item.TipoCobertura" class="form-select"><option value="AMPLIA">Amplia</option><option value="RC">RC (Responsabilidad Civil)</option><option value="LIMITADA">Limitada</option><option value="OTRA">Otra</option></select></div>
                    <div class="col-md-4"><label asp-for="Item.FechaInicio" class="form-label fw-semibold"></label><input asp-for="Item.FechaInicio" type="date" class="form-control" id="fIni" /><span asp-validation-for="Item.FechaInicio" class="text-danger small"></span></div>
                    <div class="col-md-4"><label asp-for="Item.FechaFin" class="form-label fw-semibold"></label><input asp-for="Item.FechaFin" type="date" class="form-control" id="fFin" /><span asp-validation-for="Item.FechaFin" class="text-danger small"></span></div>
                    <div class="col-md-4"><label asp-for="Item.PrimaTotal" class="form-label fw-semibold"></label><input asp-for="Item.PrimaTotal" type="number" step="0.01" min="0" class="form-control" id="prima" /><span asp-validation-for="Item.PrimaTotal" class="text-danger small"></span></div>
                    <div class="col-md-4"><label asp-for="Item.Moneda" class="form-label fw-semibold"></label><select asp-for="Item.Moneda" class="form-select"><option value="HNL">HNL</option><option value="USD">USD</option></select></div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Costo diario estimado</label>
                        <div class="input-group"><input type="text" id="costoDia" class="form-control bg-light fw-bold" readonly style="color:#20c997;" /><span class="input-group-text">/día</span></div>
                        <small class="text-muted">prima ÷ días de vigencia</small>
                    </div>
                    <div class="col-12"><label asp-for="Item.Observaciones" class="form-label fw-semibold"></label><input asp-for="Item.Observaciones" class="form-control" /></div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 px-4 pb-4 d-flex gap-2">
                <button type="submit" class="btn text-white" style="background-color:#20c997;"><i class="fas fa-save me-2"></i>Guardar</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function calcSeguro() {
            const ini = new Date(document.getElementById('fIni').value);
            const fin = new Date(document.getElementById('fFin').value);
            const prima = parseFloat(document.getElementById('prima').value) || 0;
            if (ini && fin && fin >= ini) {
                const dias = Math.round((fin - ini) / 86400000) + 1;
                document.getElementById('costoDia').value = dias > 0 ? (prima / dias).toFixed(4) : '';
            }
        }
        ['fIni','fFin','prima'].forEach(id => document.getElementById(id).addEventListener('input', calcSeguro));
    </script>
}
