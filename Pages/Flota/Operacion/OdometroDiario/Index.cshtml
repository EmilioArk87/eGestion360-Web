@page
@model eGestion360Web.Pages.Flota.Operacion.OdometroDiario.IndexModel
@{
    ViewData["Title"] = "Odómetro Diario";
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/MainMenu">Menú Principal</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Index">Flota & KPIs</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Operacion/Index">Operación Diaria</a></li>
            <li class="breadcrumb-item active">Odómetro</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="fas fa-tachometer-alt me-2" style="color:#0d6efd;"></i>Odómetro Diario</h2>
            <p class="text-muted mb-0">Registro de kilómetros inicial y final por vehículo</p>
        </div>
        <a asp-page="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nuevo Registro
        </a>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="get" class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Fecha desde</label>
                    <input type="date" name="Desde" value="@Model.Desde?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Fecha hasta</label>
                    <input type="date" name="Hasta" value="@Model.Hasta?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-outline-primary flex-grow-1">Filtrar</button>
                    <a asp-page="Index" class="btn btn-outline-secondary">Limpiar</a>
                </div>
            </div>
        </div>
    </form>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha</th>
                            <th>Vehículo</th>
                            <th>Ruta</th>
                            <th class="text-end">KM Inicial</th>
                            <th class="text-end">KM Final</th>
                            <th class="text-end fw-bold">KM Recorridos</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Registros.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    <i class="fas fa-tachometer-alt fa-2x mb-2 d-block text-secondary"></i>
                                    No hay registros en el período seleccionado.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var r in Model.Registros)
                            {
                                <tr>
                                    <td>@r.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td><strong>@r.Vehiculo?.Placa</strong></td>
                                    <td>@(r.Ruta?.Nombre ?? "-")</td>
                                    <td class="text-end">@r.KmInicial.ToString("N2")</td>
                                    <td class="text-end">@r.KmFinal.ToString("N2")</td>
                                    <td class="text-end fw-bold text-primary">@r.KmRecorridos.ToString("N2")</td>
                                    <td class="text-end">
                                        <a asp-page="Edit" asp-route-id="@r.IdOdometroDiario" class="btn btn-sm btn-outline-primary" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                            <tr class="table-light fw-bold">
                                <td colspan="5" class="text-end">Total período:</td>
                                <td class="text-end text-primary">@Model.Registros.Sum(r => r.KmRecorridos).ToString("N2") km</td>
                                <td></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-page="/Flota/Operacion/Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Volver a Operación Diaria
        </a>
    </div>
</div>
