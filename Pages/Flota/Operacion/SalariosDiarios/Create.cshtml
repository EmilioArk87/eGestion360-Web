@page
@model eGestion360Web.Pages.Flota.Operacion.SalariosDiarios.CreateModel
@{
    ViewData["Title"] = "Registrar Salario Diario";
}
<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/MainMenu">Menú Principal</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Index">Flota & KPIs</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Operacion/Index">Operación Diaria</a></li>
            <li class="breadcrumb-item"><a asp-page="Index">Salarios</a></li>
            <li class="breadcrumb-item active">Nuevo</li>
        </ol>
    </nav>
    <div class="mb-4">
        <h2 class="mb-1"><i class="fas fa-money-bill-wave me-2 text-success"></i>Registrar Salario Diario</h2>
    </div>
    <form method="post">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Item.IdVehiculo" class="form-label fw-semibold"></label>
                        <select asp-for="Item.IdVehiculo" asp-items="ViewBag.Vehiculos" class="form-select">
                            <option value="">-- Seleccione --</option>
                        </select>
                        <span asp-validation-for="Item.IdVehiculo" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Item.IdPersona" class="form-label fw-semibold"></label>
                        <select asp-for="Item.IdPersona" asp-items="ViewBag.Personas" class="form-select">
                            <option value="">-- Seleccione --</option>
                        </select>
                        <span asp-validation-for="Item.IdPersona" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Item.Fecha" class="form-label fw-semibold"></label>
                        <input asp-for="Item.Fecha" type="date" class="form-control" />
                        <span asp-validation-for="Item.Fecha" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Item.Cargo" class="form-label fw-semibold"></label>
                        <select asp-for="Item.Cargo" class="form-select">
                            <option value="CONDUCTOR">Conductor</option>
                            <option value="COBRADOR">Cobrador</option>
                            <option value="MECANICO">Mecánico</option>
                            <option value="SUPERVISOR">Supervisor</option>
                            <option value="OTRO">Otro</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Item.Monto" class="form-label fw-semibold"></label>
                        <input asp-for="Item.Monto" type="number" step="0.01" min="0" class="form-control" />
                        <span asp-validation-for="Item.Monto" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Item.Moneda" class="form-label fw-semibold"></label>
                        <select asp-for="Item.Moneda" class="form-select">
                            <option value="HNL">HNL — Lempiras</option>
                            <option value="USD">USD — Dólares</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label asp-for="Item.Observaciones" class="form-label fw-semibold"></label>
                        <input asp-for="Item.Observaciones" class="form-control" />
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 px-4 pb-4 d-flex gap-2">
                <button type="submit" class="btn btn-success"><i class="fas fa-save me-2"></i>Guardar</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
