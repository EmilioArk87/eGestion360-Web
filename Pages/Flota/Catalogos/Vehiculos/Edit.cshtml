@page "{id:int}"
@model eGestion360Web.Pages.Flota.Catalogos.Vehiculos.EditModel
@{
    ViewData["Title"] = "Editar Vehículo";
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/MainMenu">Menú Principal</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Catalogos/Index">Catálogos Flota</a></li>
            <li class="breadcrumb-item"><a asp-page="Index">Vehículos</a></li>
            <li class="breadcrumb-item active">Editar — @Model.Vehiculo.Placa</li>
        </ol>
    </nav>

    <div class="mb-4">
        <h2 class="mb-1"><i class="fas fa-edit me-2" style="color:#6610f2;"></i>Editar Vehículo</h2>
        <p class="text-muted mb-0">Placa: <strong>@Model.Vehiculo.Placa</strong></p>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Vehiculo.IdVehiculo" />
        <input type="hidden" asp-for="Vehiculo.IdEmpresa" />
        <input type="hidden" asp-for="Vehiculo.TokenConcurrencia" />

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <partial name="_VehiculoForm" model="Model.Vehiculo" />
            </div>
            <div class="card-footer bg-transparent border-0 px-4 pb-4 d-flex gap-2">
                <button type="submit" class="btn text-white" style="background-color:#6610f2;">
                    <i class="fas fa-save me-2"></i>Guardar Cambios
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-times me-2"></i>Cancelar
                </a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
