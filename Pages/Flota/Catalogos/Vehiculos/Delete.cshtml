@page "{id:int}"
@model eGestion360Web.Pages.Flota.Catalogos.Vehiculos.DeleteModel
@{
    ViewData["Title"] = "Eliminar Vehículo";
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/MainMenu">Menú Principal</a></li>
            <li class="breadcrumb-item"><a asp-page="/Flota/Catalogos/Index">Catálogos Flota</a></li>
            <li class="breadcrumb-item"><a asp-page="Index">Vehículos</a></li>
            <li class="breadcrumb-item active">Eliminar</li>
        </ol>
    </nav>

    <div class="mb-4">
        <h2 class="mb-1 text-danger"><i class="fas fa-trash me-2"></i>Eliminar Vehículo</h2>
        <p class="text-muted mb-0">Esta acción desactivará el vehículo del sistema (eliminación lógica).</p>
    </div>

    <div class="card border-danger border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="alert alert-warning d-flex align-items-center mb-4">
                <i class="fas fa-exclamation-triangle fa-lg me-3"></i>
                <div>¿Confirma que desea eliminar el vehículo <strong>@Model.Vehiculo.Placa</strong>?
                Los registros históricos de este vehículo se conservarán.</div>
            </div>

            <dl class="row mb-0">
                <dt class="col-sm-3">Placa</dt>
                <dd class="col-sm-9"><strong>@Model.Vehiculo.Placa</strong></dd>

                <dt class="col-sm-3">Número interno</dt>
                <dd class="col-sm-9">@(Model.Vehiculo.NumeroInterno ?? "-")</dd>

                <dt class="col-sm-3">Tipo</dt>
                <dd class="col-sm-9">@(Model.Vehiculo.TipoVehiculo?.Nombre ?? "-")</dd>

                <dt class="col-sm-3">Marca / Modelo</dt>
                <dd class="col-sm-9">@($"{Model.Vehiculo.Marca} {Model.Vehiculo.Modelo}".Trim())</dd>

                <dt class="col-sm-3">Año</dt>
                <dd class="col-sm-9">@(Model.Vehiculo.Anio?.ToString() ?? "-")</dd>
            </dl>
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Vehiculo.IdVehiculo" />
        <input type="hidden" asp-for="Vehiculo.TokenConcurrencia" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">
                <i class="fas fa-trash me-2"></i>Confirmar Eliminación
            </button>
            <a asp-page="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Cancelar
            </a>
        </div>
    </form>
</div>
