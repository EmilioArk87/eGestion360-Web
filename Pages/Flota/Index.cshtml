@page
@model eGestion360Web.Pages.Flota.IndexModel
@{
    ViewData["Title"] = "Flota & KPIs";
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/MainMenu">Menú Principal</a></li>
            <li class="breadcrumb-item active">Flota & KPIs</li>
        </ol>
    </nav>

    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-1"><i class="fas fa-truck me-2" style="color:#6610f2;"></i>Flota & KPIs</h2>
            <p class="text-muted mb-0">Control de gastos y costo por kilómetro de la flota de vehículos</p>
        </div>
    </div>

    <div class="row g-4">

        <!-- Dashboard KPI -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 menu-card">
                <div class="card-body text-center p-4">
                    <div class="menu-icon text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 4rem; height: 4rem; background-color: #6610f2;">
                        <i class="fas fa-chart-bar fa-lg"></i>
                    </div>
                    <h6 class="card-title fw-bold mb-2">Dashboard KPI</h6>
                    <p class="card-text text-muted small mb-3">Costo por kilómetro por vehículo y período</p>
                    <a asp-page="/Flota/KPI/Dashboard" class="btn btn-sm w-100 text-white" style="background-color:#6610f2;">
                        <i class="fas fa-arrow-right me-1"></i>Ver KPIs
                    </a>
                </div>
            </div>
        </div>

        <!-- Operación Diaria -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 menu-card">
                <div class="card-body text-center p-4">
                    <div class="menu-icon text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 4rem; height: 4rem; background-color: #0d6efd;">
                        <i class="fas fa-calendar-day fa-lg"></i>
                    </div>
                    <h6 class="card-title fw-bold mb-2">Operación Diaria</h6>
                    <p class="card-text text-muted small mb-3">Odómetro, combustible y salarios del día</p>
                    <a asp-page="/Flota/Operacion/Index" class="btn btn-sm w-100 text-white" style="background-color:#0d6efd;">
                        <i class="fas fa-arrow-right me-1"></i>Registrar
                    </a>
                </div>
            </div>
        </div>

        <!-- Gastos Periódicos -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 menu-card">
                <div class="card-body text-center p-4">
                    <div class="menu-icon bg-warning text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 4rem; height: 4rem;">
                        <i class="fas fa-file-invoice-dollar fa-lg"></i>
                    </div>
                    <h6 class="card-title fw-bold mb-2">Gastos Periódicos</h6>
                    <p class="card-text text-muted small mb-3">Repuestos, mantenimiento y seguros</p>
                    <a asp-page="/Flota/Gastos/Index" class="btn btn-sm btn-warning w-100 text-white">
                        <i class="fas fa-arrow-right me-1"></i>Registrar
                    </a>
                </div>
            </div>
        </div>

        <!-- Catálogos -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 menu-card">
                <div class="card-body text-center p-4">
                    <div class="menu-icon bg-secondary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 4rem; height: 4rem;">
                        <i class="fas fa-list-alt fa-lg"></i>
                    </div>
                    <h6 class="card-title fw-bold mb-2">Catálogos</h6>
                    <p class="card-text text-muted small mb-3">Vehículos, rutas, personal, talleres</p>
                    <a asp-page="/Flota/Catalogos/Index" class="btn btn-sm btn-secondary w-100">
                        <i class="fas fa-arrow-right me-1"></i>Gestionar
                    </a>
                </div>
            </div>
        </div>

        <!-- Referencias -->
        @if (Model.IsAdmin)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0 menu-card">
                    <div class="card-body text-center p-4">
                        <div class="menu-icon text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                             style="width: 4rem; height: 4rem; background-color:#20c997;">
                            <i class="fas fa-database fa-lg"></i>
                        </div>
                        <h6 class="card-title fw-bold mb-2">Referencias</h6>
                        <p class="card-text text-muted small mb-3">Tasas BCH y precios combustible SEN</p>
                        <a asp-page="/Admin/Referencias/Index" class="btn btn-sm w-100 text-white" style="background-color:#20c997;">
                            <i class="fas fa-arrow-right me-1"></i>Gestionar
                        </a>
                    </div>
                </div>
            </div>
        }

    </div>

    <div class="mt-4">
        <a asp-page="/MainMenu" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Volver al Menú Principal
        </a>
    </div>
</div>

@section Scripts {
    <style>
        .menu-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
        .menu-card:hover { transform: translateY(-4px); box-shadow: 0 0.4rem 1rem rgba(0,0,0,.12) !important; }
    </style>
}
