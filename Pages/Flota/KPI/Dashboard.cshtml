@page
@model eGestion360Web.Pages.Flota.KPI.DashboardModel
@{
    ViewData["Title"] = "KPI – Costo por Kilómetro";
    string Fmt(decimal v) => v.ToString("N2");
    string FmtKm(decimal v) => v.ToString("N0");
}

<div class="container-fluid">

    <!-- Encabezado -->
    <div class="row mb-3">
        <div class="col">
            <h3 class="fw-bold mb-0">
                <i class="fas fa-tachometer-alt me-2 text-primary"></i>KPI — Costo por Kilómetro (L/KM)
            </h3>
            <p class="text-muted mb-0">Costo operativo total dividido entre kilómetros recorridos por vehículo.</p>
        </div>
        <div class="col-auto">
            <a asp-page="/Flota/Index" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left me-1"></i>Volver a Flota
            </a>
        </div>
    </div>

    <!-- Filtro de fechas -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body py-3">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label fw-semibold mb-1">Desde</label>
                    <input type="date" name="FechaDesde" class="form-control form-control-sm"
                           value="@Model.FechaDesde.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-auto">
                    <label class="form-label fw-semibold mb-1">Hasta</label>
                    <input type="date" name="FechaHasta" class="form-control form-control-sm"
                           value="@Model.FechaHasta.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fas fa-search me-1"></i>Calcular
                    </button>
                </div>
                <!-- Atajos de período -->
                <div class="col-auto ms-2">
                    @{
                        var hoy = DateOnly.FromDateTime(DateTime.Today);
                        var inicioMes = new DateOnly(hoy.Year, hoy.Month, 1);
                        var inicioMesAnt = inicioMes.AddMonths(-1);
                        var finMesAnt = inicioMes.AddDays(-1);
                        var inicioSemana = hoy.AddDays(-(int)hoy.DayOfWeek + 1);
                    }
                    <a href="?FechaDesde=@inicioMes.ToString("yyyy-MM-dd")&FechaHasta=@hoy.ToString("yyyy-MM-dd")"
                       class="btn btn-outline-secondary btn-sm me-1">Este mes</a>
                    <a href="?FechaDesde=@inicioMesAnt.ToString("yyyy-MM-dd")&FechaHasta=@finMesAnt.ToString("yyyy-MM-dd")"
                       class="btn btn-outline-secondary btn-sm me-1">Mes anterior</a>
                    <a href="?FechaDesde=@inicioSemana.ToString("yyyy-MM-dd")&FechaHasta=@hoy.ToString("yyyy-MM-dd")"
                       class="btn btn-outline-secondary btn-sm">Esta semana</a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Resultados.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            No hay datos de operación registrados para el período
            <strong>@Model.FechaDesde.ToString("dd/MM/yyyy") – @Model.FechaHasta.ToString("dd/MM/yyyy")</strong>.
        </div>
    }
    else
    {
        <!-- Tarjetas KPI resumen -->
        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <p class="text-muted mb-1 small">L/KM Promedio Flota</p>
                        <h2 class="fw-bold text-primary mb-0">L @Fmt(Model.LkmPromedio)</h2>
                        <small class="text-muted">Costo total / KM totales</small>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <p class="text-muted mb-1 small">KM Totales Flota</p>
                        <h2 class="fw-bold text-success mb-0">@FmtKm(Model.KmTotalFlota) km</h2>
                        <small class="text-muted">Suma de todos los vehículos</small>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <p class="text-muted mb-1 small">Costo Total Flota</p>
                        <h2 class="fw-bold text-danger mb-0">L @Fmt(Model.CostoTotalFlota)</h2>
                        <small class="text-muted">Todos los componentes</small>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <p class="text-muted mb-1 small">Vehículos con actividad</p>
                        <h2 class="fw-bold mb-0">@Model.Resultados.Count</h2>
                        <small class="text-muted">En el período seleccionado</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Desglose de costos (barra proporcional) -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold">Composición del costo total</div>
            <div class="card-body pb-2">
                @if (Model.CostoTotalFlota > 0)
                {
                    decimal pct(decimal v) => Math.Round(v / Model.CostoTotalFlota * 100, 1);
                    <div class="progress mb-3" style="height:28px">
                        @if (Model.TotalCombustible > 0)
                        {
                            <div class="progress-bar bg-warning text-dark" style="width:@pct(Model.TotalCombustible)%"
                                 title="Combustible">
                                Combustible @pct(Model.TotalCombustible)%
                            </div>
                        }
                        @if (Model.TotalSalarios > 0)
                        {
                            <div class="progress-bar bg-success" style="width:@pct(Model.TotalSalarios)%"
                                 title="Salarios">
                                Salarios @pct(Model.TotalSalarios)%
                            </div>
                        }
                        @if (Model.TotalRepuestos > 0)
                        {
                            <div class="progress-bar bg-info" style="width:@pct(Model.TotalRepuestos)%"
                                 title="Repuestos">
                                Repuestos @pct(Model.TotalRepuestos)%
                            </div>
                        }
                        @if (Model.TotalMantenimiento > 0)
                        {
                            <div class="progress-bar bg-secondary" style="width:@pct(Model.TotalMantenimiento)%"
                                 title="Mantenimiento">
                                Mant. @pct(Model.TotalMantenimiento)%
                            </div>
                        }
                        @if (Model.TotalSeguros > 0)
                        {
                            <div class="progress-bar bg-danger" style="width:@pct(Model.TotalSeguros)%"
                                 title="Seguros">
                                Seguros @pct(Model.TotalSeguros)%
                            </div>
                        }
                    </div>
                    <div class="d-flex flex-wrap gap-3 small">
                        <span><span class="badge bg-warning text-dark">&nbsp;</span> Combustible: L @Fmt(Model.TotalCombustible)</span>
                        <span><span class="badge bg-success">&nbsp;</span> Salarios: L @Fmt(Model.TotalSalarios)</span>
                        <span><span class="badge bg-info">&nbsp;</span> Repuestos: L @Fmt(Model.TotalRepuestos)</span>
                        <span><span class="badge bg-secondary">&nbsp;</span> Mantenimiento: L @Fmt(Model.TotalMantenimiento)</span>
                        <span><span class="badge bg-danger">&nbsp;</span> Seguros: L @Fmt(Model.TotalSeguros)</span>
                    </div>
                }
            </div>
        </div>

        <!-- Tabla por vehículo -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold d-flex justify-content-between">
                <span>Detalle por vehículo</span>
                <small class="text-muted">@Model.FechaDesde.ToString("dd/MM/yyyy") – @Model.FechaHasta.ToString("dd/MM/yyyy")</small>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0 align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Placa</th>
                                <th>Ruta</th>
                                <th class="text-end">KM</th>
                                <th class="text-end">Combustible (L)</th>
                                <th class="text-end">Salarios (L)</th>
                                <th class="text-end">Repuestos (L)</th>
                                <th class="text-end">Mant. (L)</th>
                                <th class="text-end">Seguros (L)</th>
                                <th class="text-end fw-bold">Total (L)</th>
                                <th class="text-end fw-bold">L/KM</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var mejor = Model.Resultados.Where(r => r.KmTotal > 0).MinBy(r => r.LempirasPorKm);
                                var peor  = Model.Resultados.Where(r => r.KmTotal > 0).MaxBy(r => r.LempirasPorKm);
                            }
                            @foreach (var r in Model.Resultados)
                            {
                                string rowClass = "";
                                if (r.KmTotal > 0 && mejor != null && r.IdVehiculo == mejor.IdVehiculo && Model.Resultados.Count > 1)
                                    rowClass = "table-success";
                                else if (r.KmTotal > 0 && peor != null && r.IdVehiculo == peor.IdVehiculo && Model.Resultados.Count > 1)
                                    rowClass = "table-danger";
                                <tr class="@rowClass">
                                    <td class="fw-semibold">@r.Placa</td>
                                    <td class="text-muted">@(r.NombreRuta ?? "—")</td>
                                    <td class="text-end">@FmtKm(r.KmTotal)</td>
                                    <td class="text-end">@Fmt(r.CostoCombustible)</td>
                                    <td class="text-end">@Fmt(r.CostoSalarios)</td>
                                    <td class="text-end">@Fmt(r.CostoRepuestos)</td>
                                    <td class="text-end">@Fmt(r.CostoMantenimiento)</td>
                                    <td class="text-end">@Fmt(r.CostoSeguros)</td>
                                    <td class="text-end fw-bold">@Fmt(r.CostoTotal)</td>
                                    <td class="text-end fw-bold @(r.KmTotal == 0 ? "text-muted" : "")">
                                        @(r.KmTotal > 0 ? $"L {Fmt(r.LempirasPorKm)}" : "Sin KM")
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-dark fw-bold">
                            <tr>
                                <td colspan="2">TOTAL FLOTA</td>
                                <td class="text-end">@FmtKm(Model.KmTotalFlota)</td>
                                <td class="text-end">@Fmt(Model.TotalCombustible)</td>
                                <td class="text-end">@Fmt(Model.TotalSalarios)</td>
                                <td class="text-end">@Fmt(Model.TotalRepuestos)</td>
                                <td class="text-end">@Fmt(Model.TotalMantenimiento)</td>
                                <td class="text-end">@Fmt(Model.TotalSeguros)</td>
                                <td class="text-end">@Fmt(Model.CostoTotalFlota)</td>
                                <td class="text-end">L @Fmt(Model.LkmPromedio)</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
        <p class="text-muted small mt-2">
            <span class="badge bg-success">&nbsp;</span> Mejor L/KM &nbsp;
            <span class="badge bg-danger">&nbsp;</span> Peor L/KM
            &nbsp;· Los seguros se prorratean por días de vigencia dentro del período.
        </p>
    }
</div>
