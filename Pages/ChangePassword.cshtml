@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Cambiar Contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eGestion360</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/login.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="login-body">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="logo-container">
                    <i class="fas fa-chart-line logo-icon"></i>
                    <h2 class="login-title">eGestion360</h2>
                </div>
                <p class="login-subtitle">Cambiar contraseña</p>
            </div>

            @if (Model.IsForcedChange)
            {
                <div class="alert alert-warning" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Estás usando una contraseña temporal. Debes establecer una nueva contraseña para continuar.
                </div>
            }

            <form method="post" class="login-form">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="form-group">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="fas fa-lock"></i>
                        </span>
                        <input asp-for="CurrentPassword" class="form-control" placeholder="Contraseña actual" />
                    </div>
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="fas fa-key"></i>
                        </span>
                        <input asp-for="NewPassword" class="form-control" placeholder="Nueva contraseña" />
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="fas fa-check"></i>
                        </span>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirmar nueva contraseña" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <a href="@(Model.IsForcedChange ? "/Login" : "/UserManagement")" class="btn btn-danger btn-home" data-bs-toggle="tooltip"
                       data-bs-placement="top" title="Cancelar">
                        <i class="fas fa-times"></i>
                    </a>
                    <button type="submit" class="btn btn-primary btn-login flex-grow-1">
                        <i class="fas fa-save me-2"></i>Guardar nueva contraseña
                    </button>
                </div>
            </form>
        </div>
    </div>

    <footer class="bg-dark text-light py-4 mt-5" style="position: fixed; bottom: 0; width: 100%; left: 0;">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5><i class="fas fa-chart-line me-2"></i>eGestion360</h5>
                    <p class="mb-0">Sistema de Gestión Web desarrollado por SIP Tecnología</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-0">&copy; @DateTime.Now.Year - SIP Tecnología - Todos los derechos reservados</p>
                    <small class="text-muted">
                        <a href="#" class="text-muted me-3"><i class="fas fa-envelope me-1"></i>info@siptech.com</a>
                        <a href="#" class="text-muted"><i class="fas fa-phone me-1"></i>+1 234 567 890</a>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (el) { return new bootstrap.Tooltip(el); });
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
