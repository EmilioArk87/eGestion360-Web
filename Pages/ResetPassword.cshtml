@page
@model eGestion360Web.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Restablecer Contraseña";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card mt-5">
                <div class="card-header">
                    <h4 class="text-center"><i class="fas fa-unlock-alt"></i> Restablecer Contraseña</h4>
                </div>
                <div class="card-body">
                    @if (!Model.PasswordReset)
                    {
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                            
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i>
                                Ingresa el código de 6 dígitos que recibiste por email y tu nueva contraseña.
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Email" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-envelope"></i>
                                    </span>
                                    <input asp-for="Email" class="form-control" placeholder="tu@email.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="VerificationCode" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-key"></i>
                                    </span>
                                    <input asp-for="VerificationCode" class="form-control" placeholder="123456" maxlength="6" style="text-align: center; font-size: 1.2em; letter-spacing: 2px;" />
                                </div>
                                <span asp-validation-for="VerificationCode" class="text-danger"></span>
                                <div class="form-text">Código válido por 15 minutos</div>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="NewPassword" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-lock"></i>
                                    </span>
                                    <input asp-for="NewPassword" class="form-control" />
                                </div>
                                <span asp-validation-for="NewPassword" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="ConfirmPassword" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-lock"></i>
                                    </span>
                                    <input asp-for="ConfirmPassword" class="form-control" />
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="fas fa-check"></i> Restablecer Contraseña
                                </button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-success">
                            <h5><i class="fas fa-check-circle"></i> ¡Contraseña Actualizada!</h5>
                            <p class="mb-0">Tu contraseña ha sido cambiada exitosamente, <strong>@Model.UserUsername</strong>.</p>
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-envelope"></i>
                            Hemos enviado un email de confirmación a <strong>@Model.Email</strong>.
                        </div>

                        <div class="d-grid gap-2">
                            <a asp-page="/Login" class="btn btn-primary btn-lg">
                                <i class="fas fa-sign-in-alt"></i> Iniciar Sesión
                            </a>
                        </div>
                    }

                    <div class="text-center mt-4">
                        @if (!Model.PasswordReset)
                        {
                            <p>
                                <a asp-page="/ForgotPassword" class="text-decoration-none">
                                    <i class="fas fa-redo"></i> Solicitar Nuevo Código
                                </a>
                            </p>
                        }
                        <p>
                            <a asp-page="/Login" class="text-decoration-none">
                                <i class="fas fa-arrow-left"></i> Volver al Login
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // Auto-formatear código de verificación
        document.getElementById('VerificationCode').addEventListener('input', function(e) {
            var value = e.target.value.replace(/\D/g, ''); // Solo números
            if (value.length > 6) value = value.substring(0, 6);
            e.target.value = value;
        });
    </script>
}