@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eGestion360</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/login.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="login-body">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="logo-container">
                    <i class="fas fa-chart-line logo-icon"></i>
                    <h2 class="login-title">eGestion360</h2>
                </div>
                <p class="login-subtitle">Recuperar contraseña</p>
            </div>

            @if (Model.EmailSent)
            {
                <div class="alert alert-success" role="alert">
                    <i class="fas fa-check-circle me-2"></i>
                    Si el correo ingresado está registrado, recibirás una contraseña temporal en tu bandeja de entrada.
                </div>
                <div class="d-grid mt-3">
                    <a href="/Login" class="btn btn-primary btn-login">
                        <i class="fas fa-sign-in-alt me-2"></i>Volver al inicio de sesión
                    </a>
                </div>
            }
            else
            {
                <p class="text-muted small mb-3">
                    Ingresa tu correo electrónico y te enviaremos una contraseña temporal.
                </p>

                <form method="post" class="login-form">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>@Model.ErrorMessage
                        </div>
                    }

                    <div class="form-group">
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="fas fa-envelope"></i>
                            </span>
                            <input asp-for="Email" class="form-control" placeholder="Correo electrónico" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <a href="/Login" class="btn btn-danger btn-home" data-bs-toggle="tooltip"
                           data-bs-placement="top" title="Volver al login">
                            <i class="fas fa-arrow-left"></i>
                        </a>
                        <button type="submit" class="btn btn-primary btn-login flex-grow-1">
                            <i class="fas fa-paper-plane me-2"></i>Enviar contraseña temporal
                        </button>
                    </div>
                </form>
            }
        </div>
    </div>

    <footer class="bg-dark text-light py-4 mt-5" style="position: fixed; bottom: 0; width: 100%; left: 0;">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5><i class="fas fa-chart-line me-2"></i>eGestion360</h5>
                    <p class="mb-0">Sistema de Gestión Web desarrollado por SIP Tecnología</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-0">&copy; @DateTime.Now.Year - SIP Tecnología - Todos los derechos reservados</p>
                    <small class="text-muted">
                        <a href="#" class="text-muted me-3"><i class="fas fa-envelope me-1"></i>info@siptech.com</a>
                        <a href="#" class="text-muted"><i class="fas fa-phone me-1"></i>+1 234 567 890</a>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (el) { return new bootstrap.Tooltip(el); });
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
