@page
@model eGestion360Web.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card mt-5">
                <div class="card-header">
                    <h4 class="text-center"><i class="fas fa-key"></i> Recuperar Contraseña</h4>
                </div>
                <div class="card-body">
                    @if (!Model.EmailSent)
                    {
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                            
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i>
                                Ingresa tu email y te enviaremos un código de 6 dígitos para restablecer tu contraseña.
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Email" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-envelope"></i>
                                    </span>
                                    <input asp-for="Email" class="form-control" placeholder="tu@email.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-paper-plane"></i> Enviar Código
                                </button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-success">
                            <h5><i class="fas fa-check-circle"></i> ¡Código Enviado!</h5>
                            <p class="mb-2">Si el email <strong>@Model.Email</strong> está registrado en nuestro sistema, recibirás un código de verificación.</p>
                            
                            <div class="alert alert-warning mt-3">
                                <i class="fas fa-clock"></i>
                                <strong>Importante:</strong> El código es válido por <strong>15 minutos solamente</strong>.
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <a asp-page="/ResetPassword" asp-route-email="@Model.Email" class="btn btn-success btn-lg">
                                <i class="fas fa-unlock-alt"></i> Ingresar Código y Nueva Contraseña
                            </a>
                        </div>
                    }

                    <div class="text-center mt-4">
                        <p>
                            <a asp-page="/Login" class="text-decoration-none">
                                <i class="fas fa-arrow-left"></i> Volver al Login
                            </a>
                        </p>
                        <p>
                            ¿No tienes cuenta? 
                            <a asp-page="/Register" class="text-decoration-none">
                                <i class="fas fa-user-plus"></i> Registrarse
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}